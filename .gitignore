# Ignore dependencies
node_modules/
backend/node_modules/
frontend/node_modules/
frontend/dist/

# Ignore environment files
.env
*.env
backend/.env
frontend/.env

# Ignore OS files
.DS_Store
Thumbs.db

# Ignore logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Ignore IDE files
.vscode/
.idea/
*.swp
*.swo
*~

# Ignore build outputs
build/
dist/

# But include backend production dist (bundled server)
!backend/dist/
backend/dist/logs/
backend/dist/*.map
