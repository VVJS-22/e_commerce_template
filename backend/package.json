{
  "name": "ecom-backend",
  "version": "1.0.0",
  "description": "E-commerce backend with authentication",
  "main": "server.js",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "start": "NODE_ENV=production node server.js",
    "start:dist": "NODE_ENV=production node dist/index.js",
    "build": "ncc build server.js -o dist --minify --source-map",
    "build:full": "cd ../frontend && npm install && npm run build && cd ../backend && npm install",
    "dev": "nodemon server.js",
    "seed": "node seed.js"
  },
  "keywords": [],
